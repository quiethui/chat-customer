# ====== 应用基础 ======

# 应用名称，显示在 FastAPI 文档标题和 / 接口返回中。
APP_NAME="AI Customer Service MVP"

# ====== LLM 模型 ======

# OpenAI 兼容 API Key，LLM 调用和 embedding 均需要；本地 hash 模式可留空。
OPENAI_API_KEY=

# OpenAI 兼容 API 地址，官方 OpenAI 留空，第三方服务填写 /v1 地址。
OPENAI_BASE_URL=

# 聊天调用的大模型名称。
OPENAI_MODEL=

# ====== Embedding ======

# embedding 后端：hash 表示本地确定性哈希向量，sentence_transformers 表示使用 BAAI/bge-m3。
EMBEDDING_BACKEND=hash

# sentence_transformers 模式下使用的模型名称，hash 模式下忽略。
EMBEDDING_MODEL=BAAI/bge-m3

# HuggingFace Token，可选；需要下载私有模型或提高限额时在本地环境中配置。
HF_TOKEN=

# ====== 向量存储 ======

# 向量存储后端：memory 仅适合本地开发（重启丢失），生产请使用 milvus。
VECTOR_BACKEND=memory

# Milvus 连接地址，推荐用 APP_MILVUS_URI 避免和 pymilvus 内部变量冲突。
# Milvus Lite 本地文件示例：APP_MILVUS_URI=./milvus_demo.db
# 独立 Milvus 服务示例：APP_MILVUS_URI=http://localhost:19530
APP_MILVUS_URI=http://localhost:19530

# Milvus 认证 Token，无认证时留空。
MILVUS_TOKEN=

# Milvus collection 名称，存储文档切块和向量。
MILVUS_COLLECTION=customer_service_chunks

# ====== MySQL ======

# 主机地址，用于存储用户、会话、消息和订单数据。
MYSQL_HOST=127.0.0.1

# 端口。
MYSQL_PORT=3306

# 用户名。
MYSQL_USER=customer_service

# 密码。
MYSQL_PASSWORD=customer_service

# 数据库名，schema.sql 中的建表语句会写入该库。
MYSQL_DATABASE=customer_service

# 连接字符集。
MYSQL_CHARSET=utf8mb4

# 连接超时时间（秒）。
MYSQL_CONNECT_TIMEOUT=5

# ====== Redis ======

# 连接地址，用于缓存聊天上下文。
REDIS_URL=redis://127.0.0.1:6379/0

# 聊天上下文过期时间（秒），默认 1 天。
REDIS_CONTEXT_TTL_SECONDS=86400

# 每个会话缓存的最近上下文消息条数，超出部分从 MySQL 回填。
CHAT_CONTEXT_LIMIT=10

# ====== 用户认证 ======

# 登录 token 有效期（分钟），默认 1 天。
AUTH_SESSION_TTL_MINUTES=1440

# ====== 文档处理 ======

# 上传文件存储目录，相对于项目根目录。
UPLOAD_DIR=app/uploads

# 单个上传文件最大字节数，默认 20MB。
MAX_UPLOAD_BYTES=20971520

# 文档切块大小（字符数），文本解析后按此长度切分。
CHUNK_SIZE=800

# 相邻切块之间的重叠字符数，保证上下文连贯。
CHUNK_OVERLAP=120

# ====== 检索与回答 ======

# 向量检索返回的最相关结果数量。
TOP_K=4

# 回答中展示的参考片段数量上限。
REFERENCE_LIMIT=3

# 单个参考片段的最大字符数。
REFERENCE_MAX_CHARS=240
